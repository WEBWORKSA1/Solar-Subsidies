# SolarSubsidies.com — Environment Variables
# Copy these to Vercel → Project Settings → Environment Variables
# 
# ⚠️ NEVER commit this file with real values. The .gitignore already excludes .env*

# ==========================================================
# SUPABASE (required for lead capture)
# ==========================================================
# Get from supabase.com → your project → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
# ⚠️ Use SERVICE ROLE key not ANON key — needs write permission

# ==========================================================
# WHATSAPP BUSINESS API (recommended: AiSensy ₹999/mo for India)
# ==========================================================
WHATSAPP_PROVIDER=aisensy          # 'aisensy' | 'interakt' | 'msg91' | 'webhook'
WHATSAPP_API_KEY=YOUR_KEY_HERE
ADMIN_PHONE=+91XXXXXXXXXX          # E.164 format, your phone for new-lead alerts

# AiSensy specific
AISENSY_CAMPAIGN_NAME=lead_notification

# MSG91 specific (alternative)
MSG91_INTEGRATED_NUMBER=YOUR_NUMBER

# ==========================================================
# OPTIONAL — Analytics
# ==========================================================
POSTHOG_KEY=phc_YOUR_KEY
POSTHOG_HOST=https://app.posthog.com
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
